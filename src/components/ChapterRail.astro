---
// CAPITULA — the chapter rail. With snap scrolling, "where am I?" matters
// more than jump links: Roman numerals mark the ten rooms; the active one
// is engraved burgundy with a gold rule. Desktop only.
const chapters = [
  "top",
  "duo",
  "pillars",
  "scenarios",
  "codex",
  "privacy",
  "free",
  "faq",
  "download",
];

const numerals = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX"];
---

<nav class="chapter-rail" aria-label="Capitula">
  {chapters.map((id, i) => <a class="caps" href={`#${id}`}>{numerals[i]}</a>)}
</nav>

<style>
  .chapter-rail {
    position: fixed;
    right: 1.3rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: none;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.55rem;
  }

  @media (min-width: 1024px) and (hover: hover) {
    .chapter-rail {
      display: flex;
    }
  }

  a {
    font-size: 1.05rem;
    letter-spacing: 0.14em;
    color: var(--taupe);
    text-decoration: none;
    padding: 0.25rem 0.85rem 0.25rem 0.55rem;
    border-right: 3px solid transparent;
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease), transform 0.3s var(--ease);
    opacity: 0.85;
  }

  a:hover {
    color: var(--burgundy);
    opacity: 1;
  }

  a.active {
    color: var(--burgundy);
    border-right-color: var(--gold);
    opacity: 1;
    transform: scale(1.22);
    font-weight: 600;
  }
</style>
