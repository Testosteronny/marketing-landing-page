---
// DESCENDE — the close. The only inverted section: full-bleed burgundy,
// sharing its screen with the contact letter and the TWINT support link.
import { getDict, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const d = t.descende;
const e = t.epistula;
---

<section id="download" class="band" data-observe>
  <div class="wrap grid">
    <div class="cta-col">
      <img src="/assets/logo.svg" alt="" width="60" height="60" data-reveal />
      <h2 class="headline" data-reveal style="--i: 1">{d.headline}</h2>
      <p class="lede" data-reveal style="--i: 2">{d.lede}</p>

      <div class="badges" data-reveal style="--i: 3">
        <span class="badge caps">{d.badgeIos}</span>
        <span class="badge caps">{d.badgeAndroid}</span>
      </div>

      <a
        class="notify btn btn-primary"
        href={`mailto:hallo@sueleli.ch?subject=${encodeURIComponent(d.notifySubject)}`}
        data-reveal
        style="--i: 4"
      >
        {d.notify}
      </a>

      <p class="caps signoff" data-reveal style="--i: 5">{d.signoff}</p>
    </div>

    <div class="side-col" id="contact" data-reveal style="--i: 3">
      <form id="contact-form" class="letter" data-reply-label={e.replyLabel}>
        <p class="caps form-title">{e.latin} — {e.headline}</p>

        <label>
          <span class="caps field-label">{e.emailLabel}</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>

        <label>
          <span class="caps field-label">{e.subjectLabel}</span>
          <input type="text" name="subject" required maxlength="140" />
        </label>

        <label>
          <span class="caps field-label">{e.messageLabel}</span>
          <textarea name="message" rows="4" required></textarea>
        </label>

        <button class="btn btn-primary send" type="submit">{e.send}</button>
        <p class="form-note" id="contact-status" data-sent={e.sent} data-error={e.error}>{e.note}</p>
      </form>
    </div>
  </div>
</section>

<style>
  .band {
    background:
      radial-gradient(120% 140% at 50% -20%, rgba(230, 184, 63, 0.12), transparent 55%),
      var(--burgundy-dark);
    color: var(--parchment);
    padding-block: clamp(3rem, 7vh, 5.5rem);
    border-top: 1px solid var(--gold);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .cta-col {
    display: grid;
    justify-items: start;
    gap: 1rem;
  }

  .cta-col img {
    border-radius: 50%;
    box-shadow: 0 0 0 1px rgba(230, 184, 63, 0.4), 0 12px 34px rgba(0, 0, 0, 0.4);
  }

  .band .headline {
    color: var(--parchment);
  }

  .band .lede {
    color: var(--stone);
    max-width: 28em;
    font-size: 1.1rem;
  }

  .badges {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .badge {
    padding: 0.65rem 1.2rem;
    border: 1px solid rgba(198, 154, 61, 0.55);
    border-radius: 6px;
    color: var(--gold-bright);
    font-size: 0.66rem;
  }

  .notify {
    background: var(--gold);
    color: var(--burgundy-dark);
    border-color: var(--gold-bright);
  }

  .notify:hover {
    background: var(--gold-bright);
  }

  .signoff {
    color: var(--taupe);
    font-size: 0.62rem;
    margin-top: 0.4rem;
  }

  /* ---- the letter (contact form) ---- */
  .letter {
    background: var(--parchment-veil);
    border: 1px solid rgba(198, 154, 61, 0.4);
    border-radius: 8px;
    padding: clamp(1.3rem, 2.5vw, 1.8rem);
    display: grid;
    gap: 0.85rem;
    color: var(--ink);
  }

  .form-title {
    color: var(--burgundy);
    font-size: 0.66rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--gold);
  }

  label {
    display: grid;
    gap: 0.3rem;
  }

  .field-label {
    font-size: 0.58rem;
    color: var(--burgundy);
  }

  input,
  textarea {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--ink);
    background: var(--parchment);
    border: 1px solid var(--stone);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    transition: border-color 0.3s var(--ease);
  }

  textarea {
    resize: vertical;
    min-height: 5.5em;
  }

  input:focus-visible,
  textarea:focus-visible {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 1px var(--gold);
  }

  .send {
    justify-self: start;
    cursor: pointer;
    padding: 0.7rem 1.5rem;
    font-size: 0.72rem;
  }

  .form-note {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--taupe);
  }

  @media (max-width: 880px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  /* desktop snap mode on short screens */
  @media (min-width: 1024px) and (hover: hover) and (max-height: 860px) {
    .band {
      padding-block: 2rem;
    }

    .cta-col {
      gap: 0.7rem;
    }

    .cta-col img {
      width: 48px;
      height: 48px;
    }

    .band .headline {
      font-size: 1.9rem;
    }

    textarea {
      min-height: 4.5em;
    }
  }
</style>
