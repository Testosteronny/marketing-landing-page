---
// No bar at all: the medallion alone in the top-left corner, the language
// switcher in the top-right. Everything else lives in the page itself.
import { locales, basePath, langNames, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<header class="site-header">
  <a class="brand" href="#top" aria-label="Sueleli">
    <img src="/assets/logo.svg" alt="Sueleli" width="46" height="46" />
  </a>

  <nav class="lang caps" aria-label="Language">
    {
      locales.map((l) => (
        <a
          href={basePath(l)}
          class:list={{ current: l === lang }}
          aria-current={l === lang ? "page" : undefined}
          aria-label={langNames[l]}
          lang={l}
        >
          {l}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem clamp(1.2rem, 2.5vw, 2.2rem) 0;
    pointer-events: none;
  }

  .brand,
  .lang {
    pointer-events: auto;
  }

  .brand img {
    border-radius: 50%;
    box-shadow: 0 4px 16px rgba(41, 36, 32, 0.18);
    transition: transform 0.3s var(--ease);
  }

  .brand:hover img {
    transform: scale(1.06);
  }

  .lang {
    display: flex;
    gap: 0.1rem;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 248, 239, 0.82);
    border: 1px solid var(--stone);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }

  .lang a {
    padding: 0.4rem 0.5rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--taupe);
    transition: color 0.3s var(--ease);
  }

  .lang a:hover {
    color: var(--burgundy);
  }

  .lang a.current {
    color: var(--burgundy);
    border-bottom: 1px solid var(--gold);
  }
</style>
