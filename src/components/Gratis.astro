---
import ChapterHead from "./ChapterHead.astro";
import { getDict, type Lang } from "../i18n";

// PRETIUM TUUM — the three vows as engraved cards, the TWINT button
// enthroned between gold hairlines.

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang).gratis;
---

<section id="free" class="chapter" data-observe>
  <div class="wrap">
    <ChapterHead latin={t.latin} translation={t.translation} headline={t.headline} />

    <div class="vows">
      {
        t.vows.map((v, i) => (
          <article class="vow veil" data-reveal style={`--i: ${i + 2}`}>
            <span class="vow-icon" aria-hidden="true">
              {i === 0 && (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                  <rect x="4" y="10.5" width="16" height="10" rx="1.5" />
                  <path d="M8 10.5V7a4 4 0 0 1 7.8-1.3" />
                  <circle cx="12" cy="15.5" r="1.6" fill="currentColor" stroke="none" />
                </svg>
              )}
              {i === 1 && (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                  <line x1="12" y1="3.5" x2="12" y2="20.5" />
                  <line x1="5" y1="6.5" x2="19" y2="6.5" />
                  <path d="M5 6.5 L2.6 12.5 a2.6 2.6 0 0 0 4.8 0 Z" />
                  <path d="M19 6.5 L16.6 12.5 a2.6 2.6 0 0 0 4.8 0 Z" />
                  <line x1="9" y1="20.5" x2="15" y2="20.5" />
                </svg>
              )}
              {i === 2 && (
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                  <circle cx="12" cy="11" r="7" />
                  <path d="M9.2 11.2l2 2 3.6-4" />
                  <path d="M8.5 17.5 7 21.5l5-2 5 2-1.5-4" />
                </svg>
              )}
            </span>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </article>
        ))
      }
    </div>

    <div class="donate" data-reveal style="--i: 5">
      <span class="hairline" aria-hidden="true"></span>
      <a
        class="twint-btn"
        href="https://go.twint.ch/1/e/tw?tw=acq.H7Pd-0BfRQOFAkvTlTd0YHZ8cRgUlu0QDkAB2iSMkewJtZkFArd3XRV9S9uhzKXJ."
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.donateBtn}
      >
        <img src="/assets/twint-button.png" alt={t.donateBtn} height="64" />
      </a>
      <span class="hairline flip" aria-hidden="true"></span>
    </div>
    <p class="muted donate-note" data-reveal style="--i: 6">{t.donateNote}</p>
  </div>
</section>

<style>
  .vows {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.4rem, 3vw, 2.4rem);
  }

  .vow {
    padding: 1.8rem 1.7rem 1.5rem;
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 0.6rem;
  }

  .vow-icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border: 1px solid var(--gold);
    border-radius: 50%;
    color: var(--burgundy);
    background: var(--parchment);
    margin-bottom: 0.3rem;
  }

  .vow h3 {
    font-size: 1.45rem;
    color: var(--burgundy);
  }

  .vow p {
    font-size: 1.05rem;
  }

  /* the TWINT button, enthroned between gold hairlines */
  .donate {
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.4rem);
    margin-top: clamp(2.2rem, 5vh, 3.4rem);
  }

  .hairline {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold));
  }

  .hairline.flip {
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .twint-btn {
    display: inline-block;
    line-height: 0;
    transition: transform 0.3s var(--ease), filter 0.3s var(--ease);
  }

  .twint-btn:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 10px 18px rgba(41, 36, 32, 0.25));
  }

  .twint-btn img {
    height: 64px;
    width: auto;
    display: block;
  }

  .donate-note {
    text-align: center;
    font-size: 0.98rem;
    font-style: italic;
    margin-top: 0.9rem;
  }

  @media (max-width: 720px) {
    .vows {
      grid-template-columns: 1fr;
    }
  }

  /* desktop snap mode on short screens */
  @media (min-width: 1024px) and (hover: hover) and (max-height: 860px) {
    .vow {
      padding: 1.2rem 1.4rem 1.1rem;
    }

    .vow-icon {
      width: 44px;
      height: 44px;
    }

    .donate {
      margin-top: 1.6rem;
    }
  }
</style>
