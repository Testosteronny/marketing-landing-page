---
interface Props {
  latin: string;
  translation: string;
  headline: string;
}

const { latin, translation, headline } = Astro.props;
---

<header class="chapter-head">
  <p class="chapter-eyebrow caps" data-reveal>
    {latin}
    <span class="translation">{translation}</span>
  </p>
  <h2 class="headline" data-reveal style="--i: 1">{headline}</h2>
  <div class="rule" aria-hidden="true"></div>
</header>
