---
import ChapterHead from "./ChapterHead.astro";
import { getDict, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
const t = dict.duo;
// small shared vignettes reuse the ledger rows and pension figures
const rows = dict.codex.entries.slice(0, 3);
const perMonth = dict.pillars.sim.perMonth;
---

<section id="duo" class="chapter" data-observe>
  <div class="wrap">
    <ChapterHead latin={t.latin} translation={t.translation} headline={t.headline} />

    <div class="horizons">
      <article data-reveal style="--i: 2">
        <p class="caps horizon-label">{t.todayLabel}</p>
        <h3>{t.todayTitle}</h3>
        <p>{t.todayText}</p>

        <!-- mini ledger vignette -->
        <div class="vignette veil" aria-hidden="true">
          <ul class="mini-ledger num">
            {
              rows.map((e) => (
                <li>
                  <span class="payee">{e.payee}</span>
                  <span class={`amount ${e.kind}`}>{e.amount}</span>
                </li>
              ))
            }
          </ul>
          <div class="mini-bar"><div class="fill"></div></div>
        </div>
      </article>

      <div class="divider" aria-hidden="true"></div>

      <article data-reveal style="--i: 3">
        <p class="caps horizon-label">{t.tomorrowLabel}</p>
        <h3>{t.tomorrowTitle}</h3>
        <p>{t.tomorrowText}</p>

        <!-- mini gauge vignette (static, 78%) -->
        <div class="vignette veil gauge-vignette" aria-hidden="true">
          <svg viewBox="0 0 220 122" class="mini-gauge">
            <path d="M20,110 A90,90 0 0 1 200,110" fill="none" stroke="var(--stone)" stroke-width="13" stroke-linecap="round" opacity="0.55" />
            <path d="M20,110 A90,90 0 0 1 35.4,59.7" fill="none" stroke="var(--burgundy)" stroke-width="13" stroke-linecap="round" />
            <path d="M35.4,59.7 A90,90 0 0 1 137.5,24.3" fill="none" stroke="var(--gold)" stroke-width="13" />
            <path d="M137.5,24.3 A90,90 0 0 1 179.3,52.6" fill="none" stroke="var(--sage)" stroke-width="13" stroke-linecap="round" />
            <text x="110" y="88" text-anchor="middle" class="mini-pct num">78%</text>
          </svg>
          <p class="mini-income num">CHF 6'240 <span class="muted">{perMonth}</span></p>
        </div>
      </article>
    </div>

    <p class="foundation muted" data-reveal style="--i: 4">{t.foundation}</p>
  </div>
</section>

<style>
  .horizons {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: start;
  }

  .horizon-label {
    color: var(--gold);
    font-size: 0.8rem;
    margin-bottom: 0.9rem;
  }

  h3 {
    font-size: 1.6rem;
    margin-bottom: 0.7rem;
  }

  .divider {
    align-self: stretch;
    background: linear-gradient(180deg, transparent, var(--stone) 20% 80%, transparent);
  }

  /* ---- vignettes ---- */
  .vignette {
    margin-top: 1.2rem;
    padding: 1.1rem 1.4rem;
    max-width: 30rem;
  }

  .mini-ledger {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mini-ledger li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(216, 200, 174, 0.55);
    font-size: 1rem;
  }

  .mini-ledger li:last-child {
    border-bottom: none;
  }

  .amount {
    font-weight: 600;
  }

  .amount.in {
    color: var(--sage);
  }

  .mini-bar {
    height: 4px;
    background: var(--stone);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.5rem;
  }

  .mini-bar .fill {
    height: 100%;
    width: 81%;
    background: var(--gold);
  }

  .gauge-vignette {
    display: grid;
    justify-items: center;
    gap: 0.2rem;
  }

  .mini-gauge {
    width: min(230px, 70%);
  }

  .mini-pct {
    font-family: var(--font-serif);
    font-size: 30px;
    font-weight: 600;
    fill: var(--burgundy);
  }

  .mini-income {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--burgundy);
  }

  .mini-income .muted {
    font-weight: 400;
    font-style: italic;
    font-size: 0.85rem;
  }

  .foundation {
    margin-top: clamp(1.8rem, 3.5vh, 2.8rem);
    padding-top: 1.2rem;
    border-top: 1px solid var(--stone);
    font-style: italic;
    text-align: center;
    max-width: 44em;
    margin-inline: auto;
  }

  @media (max-width: 720px) {
    .horizons {
      grid-template-columns: 1fr;
    }

    .divider {
      display: none;
    }
  }

  /* desktop snap mode on short screens */
  @media (min-width: 1024px) and (hover: hover) and (max-height: 860px) {
    .vignette {
      margin-top: 0.8rem;
      padding: 0.7rem 1rem;
    }

    .mini-gauge {
      width: 160px;
    }

    h3 {
      font-size: 1.4rem;
    }
  }
</style>
